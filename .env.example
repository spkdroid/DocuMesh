# ===========================================
# DocMesh Environment Configuration
# ===========================================
# Copy this file to .env and update the values.

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=docmesh
DB_PASSWORD=docmesh_secret
DB_NAME=docmesh

# Auth
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRATION=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# App
NODE_ENV=development
PORT=3000
