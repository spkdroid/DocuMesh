{
  "name": "@docmesh/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "vite --config vite.config.electron.ts",
    "electron:build": "vite build --config vite.config.electron.ts",
    "electron:preview": "electron .",
    "desktop:build": "npm run electron:build && electron-builder",
    "desktop:build:win": "npm run electron:build && electron-builder --win",
    "desktop:build:mac": "npm run electron:build && electron-builder --mac",
    "desktop:build:linux": "npm run electron:build && electron-builder --linux"
  },
  "dependencies": {
    "@tiptap/extension-highlight": "^2.1.0",
    "@tiptap/extension-placeholder": "^2.1.0",
    "@tiptap/extension-subscript": "^2.1.0",
    "@tiptap/extension-superscript": "^2.1.0",
    "@tiptap/extension-table": "^2.1.0",
    "@tiptap/extension-table-cell": "^2.1.0",
    "@tiptap/extension-table-header": "^2.1.0",
    "@tiptap/extension-table-row": "^2.1.0",
    "@tiptap/extension-underline": "^2.1.0",
    "@tiptap/pm": "^2.1.0",
    "@tiptap/react": "^2.1.0",
    "@tiptap/starter-kit": "^2.1.0",
    "axios": "^1.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
